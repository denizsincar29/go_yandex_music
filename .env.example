YA_MUSIC_ID=12345
YA_MUSIC_TOKEN=your_token_here

# Optional: Set base path for reverse proxy (e.g., /music for denizsincar.ru/music/)
# Leave empty or comment out for root path
#BASE_PATH=/music

# Optional: Enable X-Forwarded-Prefix header support (default: true)
# Modern reverse proxies can send this header to dynamically set the base path
# Set to "false" to disable and use only BASE_PATH
#USE_PROXY_HEADERS=true
